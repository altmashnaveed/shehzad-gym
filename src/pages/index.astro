---
import Layout from '../layouts/Layout.astro';
import { Dumbbell, ArrowRight, ShieldCheck, Flame, Activity, Utensils, ShoppingBag, TrendingUp, ChevronLeft, ChevronRight } from '@lucide/astro';

const reviews = [
	{ name: "Zeeshan Talat", initial: "Z", bg: "bg-blue-600", role: "1 review • 2 photos", duration: "6 months ago", text: "Allhamdollilah I have archive my Fat loss goal from Shahzad fitness gym with the instructions of Best coach in town Malik Shahzad Ahmad in just 2 months. I lost 12kg fat and now I look and feel strong now I start my new goal to build muscle" },
	{ name: "Aamir Shahzad", initial: "A", bg: "bg-orange-600", role: "2 reviews", duration: "7 months ago", text: "The staff is incredibly friendly, and the personal trainers really know their stuff and push you to achieve your goals. Stronger than yesterday, every single day. Great range of squat racks and the cardio machines are all modern and well-maintained." },
	{ name: "Kamran Hamid", initial: "K", bg: "bg-green-600", role: "2 reviews", duration: "a year ago", text: "I really enjoy working out at Shahzad Fitness Gym. The environment is friendly, and it’s always clean and comfortable. Sir Shahzad provides excellent instructions and is always supportive. This is truly one of the best gyms in Sargodha!" },
	{ name: "Asif Yousaf", initial: "A", bg: "bg-purple-600", role: "1 review", duration: "a year ago", text: "Shahzad fitness game ladies and gents is one of the best gym in Sargodha. My experience tells Shahzad gym trainer is very good. I am very happy in this gym. Perfect environment for ladies also one of the best safest place for ladies." },
	{ name: "Bilal Malik", initial: "B", bg: "bg-red-600", role: "2 reviews", duration: "2 years ago", text: "This gym is really a masterpiece in Sargodha City. The trainer is very cooperative and the gym has the best equipment for every muscle of the body. Sir Shahzad the owner and trainer have in depth knowledge about bodybuilding and physical fitness." },
	{ name: "Adnan Naeem", initial: "A", bg: "bg-emerald-600", role: "1 review • 1 photo", duration: "2 years ago", text: "I personally believe that no other club in Sargodha city has a better atmosphere. In particular, the instructor Shehzad Ahmed is a very capable person in his own right and his special training is second to none." },
	{ name: "Sajid Firoz", initial: "S", bg: "bg-indigo-600", role: "1 review", duration: "a year ago", text: "My name is Sajid Feroz Khan, age 41. I do my duty as an assistant (BPS.16) in the Education Board. Some time ago, I was suffering from severe back pain. Shahzad Fitness Gym helped me improve my health." },
	{ name: "Engr. Muneeb Sultan", initial: "M", bg: "bg-teal-600", role: "5 reviews", duration: "a year ago", text: "Beautiful gym, hygiene environment, fully equipped, best diet plans from coach, expert in body building, best training under best coach Mr sargodha Malik shahzad. Workout under Highly motivated and friendly coach." },
	{ name: "Faisal Kamboh", initial: "F", bg: "bg-cyan-600", role: "1 review", duration: "2 years ago", text: "One of the better gyms in Sargodha. Particularly the Trainer Mr. Sehzad who himself has remained Mr. Sargodha trains very nicely and efficiently and assists the guys working out. I have been to this gym for quite a good time and I have really liked it." },
	{ name: "Talha Zahid", initial: "T", bg: "bg-rose-600", role: "1 review • 1 photo", duration: "a year ago", text: "I’m excited to share my body transformation journey with everyone. A huge shoutout to Sir Shahzad, who pushed me beyond my limits and worked tirelessly to help me achieve these results. His dedication and expertise made all the difference." },
	{ name: "Rana Hammad", initial: "R", bg: "bg-pink-600", role: "1 review", duration: "a year ago", text: "This gym is a very high level gym. I have been in this team for about 1.5 years. Their machinery etc. are very good. Everything is very good. Visit this place once. You will know everything. After that, you will forget all the gyms." },
	{ name: "Abdul Wahab Maitla", initial: "A", bg: "bg-yellow-600", role: "8 reviews • 9 photos", duration: "a year ago", text: "Well facilitated gym, well disciplined, well managed. Besides all, personal training is transforming." }
];
---

<Layout title="Shahzad Fitness Gym - Sargodha | Mr. Sargodha Champion Trainer">
	<!-- Hero Section -->
	<section class="relative min-h-[95vh] flex items-center justify-center overflow-hidden bg-[#050505]">
		
		<!-- Background Image with Overlay -->
		<div class="absolute inset-0 z-0">
			<img 
				src="/malik-shehzad-hero-bg.png" 
				alt="Shahzad Fitness Gym Athlete" 
				class="w-full h-full object-cover object-[78%_center] md:object-center opacity-70 md:opacity-85 scale-100"
			/>
			<!-- Gradient Overlay for readability -->
			<div class="absolute inset-0 bg-gradient-to-t from-[#050505] via-transparent to-transparent md:via-[#050505]/70 md:to-[#050505]/30"></div>
			<div class="absolute inset-0 bg-gradient-to-r from-[#050505] via-[#050505]/75 to-transparent md:via-[#050505]/35"></div>
		</div>

		<!-- Main Hero Content -->
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full pt-12 pb-20">
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
				
				<!-- Text Column -->
				<div class="lg:col-span-8 space-y-8 text-left">
					
					<!-- Tagline badge -->
					<div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-yellow-400/10 border border-yellow-400/30 text-yellow-400 text-xs sm:text-sm font-semibold tracking-wide uppercase">
						<Flame class="w-4 h-4 fill-current animate-bounce" />
						Sargodha's Premier Fitness Destination
					</div>

					<!-- Main Headings -->
					<div class="space-y-4">
						<h1 class="text-4xl sm:text-6xl lg:text-8xl font-black tracking-tight text-white uppercase leading-[0.95]">
							Build Your<br />
							<span class="text-transparent bg-clip-text bg-gradient-to-r from-yellow-400 via-amber-300 to-yellow-500">
								Ultimate Body
							</span>
						</h1>
						<p class="text-zinc-400 text-base sm:text-lg lg:text-xl max-w-2xl font-light leading-relaxed">
							Train under <span class="text-white font-semibold">Malik Shahzad Ahmed</span> (Multi-Title Champion & Mr. Sargodha Division) in a fully-equipped facility featuring a premium cardio suite, free weights, customized diet plans, and progress tracking.
						</p>
					</div>

					<!-- Bullet Points -->
					<div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-xl text-zinc-300">
						<div class="flex items-center gap-3">
							<div class="flex items-center justify-center w-5 h-5 rounded-full bg-yellow-400/20 text-yellow-400">
								<ShieldCheck class="w-4 h-4 stroke-[2.5]" />
							</div>
							<span class="text-sm font-medium">Multi-Title Champion Trainer</span>
						</div>
						<div class="flex items-center gap-3">
							<div class="flex items-center justify-center w-5 h-5 rounded-full bg-yellow-400/20 text-yellow-400">
								<ShieldCheck class="w-4 h-4 stroke-[2.5]" />
							</div>
							<span class="text-sm font-medium">Full Cardio & Strength Suite</span>
						</div>
						<div class="flex items-center gap-3">
							<div class="flex items-center justify-center w-5 h-5 rounded-full bg-yellow-400/20 text-yellow-400">
								<ShieldCheck class="w-4 h-4 stroke-[2.5]" />
							</div>
							<span class="text-sm font-medium">Custom Diet & Meal Plans</span>
						</div>
						<div class="flex items-center gap-3">
							<div class="flex items-center justify-center w-5 h-5 rounded-full bg-yellow-400/20 text-yellow-400">
								<ShieldCheck class="w-4 h-4 stroke-[2.5]" />
							</div>
							<span class="text-sm font-medium">Flexible Ladies & Gents Hours</span>
						</div>
					</div>

					<!-- CTA Buttons -->
					<div class="flex flex-col sm:flex-row gap-4 pt-4">
						<a href="#timings" class="group inline-flex items-center justify-center gap-2 px-8 py-4 bg-yellow-400 hover:bg-yellow-300 text-zinc-950 font-extrabold rounded-full shadow-lg shadow-yellow-400/10 hover:shadow-yellow-400/20 transition-all duration-300 hover:scale-[1.03]">
							Get Timings & Schedule
							<ArrowRight class="w-5 h-5 group-hover:translate-x-1 transition-transform" />
						</a>
						<a href="#pricing" class="inline-flex items-center justify-center px-8 py-4 bg-zinc-900/80 hover:bg-zinc-800 border border-zinc-800 hover:border-zinc-700 text-zinc-300 font-semibold rounded-full transition-all duration-300 hover:scale-[1.03] backdrop-blur-sm">
							View Membership Plans
						</a>
					</div>

				</div>

			</div>
		</div>

		<!-- Scroll Indicator -->
		<div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 hidden md:flex flex-col items-center gap-2">
			<span class="text-xs font-semibold text-zinc-500 uppercase tracking-widest">Scroll</span>
			<div class="w-6 h-10 rounded-full border-2 border-zinc-800 flex justify-center p-1.5">
				<div class="w-1.5 h-1.5 rounded-full bg-yellow-400 animate-bounce"></div>
			</div>
		</div>

	</section>

	<!-- Stats Strip Section -->
	<div class="bg-gradient-to-r from-yellow-400 via-yellow-300 to-yellow-500 border-y border-yellow-500 relative z-20 py-8 shadow-lg shadow-yellow-400/5">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-4 text-center">
				<div class="space-y-1">
					<p class="text-xs font-black uppercase text-amber-950 tracking-widest">Head Coach Titles</p>
					<p class="text-2xl sm:text-3xl font-black text-zinc-950 uppercase">Multi-Title Champion</p>
					<p class="text-zinc-800 text-xs font-semibold">Mr. Sargodha Div & 3x Mr. Punjab Runner-Up</p>
				</div>
				<div class="space-y-1 md:border-x md:border-zinc-950/15 px-4">
					<p class="text-xs font-black uppercase text-amber-950 tracking-widest">Active Experience</p>
					<p class="text-2xl sm:text-3xl font-black text-zinc-950 uppercase">20+ Years</p>
					<p class="text-zinc-800 text-xs font-semibold">Professional Fitness Coaching</p>
				</div>
				<div class="space-y-1">
					<p class="text-xs font-black uppercase text-amber-950 tracking-widest">Client Satisfaction</p>
					<p class="text-2xl sm:text-3xl font-black text-zinc-950 uppercase">5.0 ★★★★★</p>
					<p class="text-zinc-800 text-xs font-semibold">160+ Happy Member Reviews</p>
				</div>
			</div>
		</div>
	</div>

	<!-- Trainer Section (Meet Malik Shahzad) -->
	<section id="about" class="py-24 bg-[#0d0d0f] relative">
		<!-- Background grids -->
		<div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_left,rgba(250,204,21,0.02)_0,transparent_50%)]"></div>
		
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
				
				<!-- Image Column -->
				<div class="lg:col-span-5 relative group">
					<!-- Border Accent Backdrop -->
					<div class="absolute -inset-2 rounded-2xl bg-gradient-to-r from-yellow-400 to-amber-500 opacity-20 blur-sm group-hover:opacity-30 transition-all duration-300"></div>
					<!-- Yellow Offset frame -->
					<div class="absolute inset-0 border-2 border-yellow-400 rounded-2xl translate-x-4 translate-y-4 -z-10 group-hover:translate-x-3 group-hover:translate-y-3 transition-transform duration-300"></div>
					
					<div class="relative overflow-hidden rounded-2xl border border-zinc-800 bg-zinc-900">
						<img 
							src="/malik-shehzad-coach.png" 
							alt="Trainer Malik Shahzad Ahmed - Mr. Sargodha Champion" 
							class="w-full h-auto object-cover object-center group-hover:scale-105 transition-transform duration-500"
						/>
					</div>
				</div>

				<!-- Content Column -->
				<div class="lg:col-span-7 space-y-8">
					<div class="space-y-4">
						<span class="text-sm font-bold text-yellow-400 uppercase tracking-widest block">Meet Your Head Trainer</span>
						<h2 class="text-3xl sm:text-5xl font-black text-white uppercase tracking-tight">
							Malik Shahzad Ahmed
						</h2>
						<p class="text-lg font-semibold text-zinc-300">
							Multi-Title Champion & Certified Fitness Coach
						</p>
					</div>

					<p class="text-zinc-400 font-light leading-relaxed">
						With over <strong class="text-white font-semibold">20+ years</strong> of active bodybuilding and personal coaching experience, Malik Shahzad Ahmed has built a reputation in Sargodha for delivering real results. As a former title winner of the prestigious <strong class="text-yellow-400 font-semibold">"Mr. Sargodha"</strong> competition, he applies professional, tested bodybuilding and conditioning methodologies to every member's training regimen.
					</p>

					<!-- Key Training Philosophies -->
					<div class="space-y-6">
						
						<!-- Tracking -->
						<div class="flex gap-4">
							<div class="flex items-center justify-center w-12 h-12 rounded-xl bg-zinc-900 border border-zinc-800 text-yellow-400 shrink-0">
								<svg class="w-6 h-6 fill-none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
								</svg>
							</div>
							<div>
								<h3 class="text-white font-bold text-base uppercase">Scientific Progress Tracking</h3>
								<p class="text-zinc-500 text-sm mt-1 leading-relaxed">
									We use dedicated progress tracking sheets measuring weight, height, age, chest, arms, abdomen, hips, and thighs to map out your muscle growth and fat loss journey.
								</p>
							</div>
						</div>

						<!-- Diet Plan -->
						<div class="flex gap-4">
							<div class="flex items-center justify-center w-12 h-12 rounded-xl bg-zinc-900 border border-zinc-800 text-yellow-400 shrink-0">
								<svg class="w-6 h-6 fill-none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
								</svg>
							</div>
							<div>
								<h3 class="text-white font-bold text-base uppercase">Customized Diet & Meal Plans</h3>
								<p class="text-zinc-500 text-sm mt-1 leading-relaxed">
									Nutrition is 70% of fitness. Receive customized, highly specific diet plans designed around your daily schedule, budget, and physical goals.
								</p>
							</div>
						</div>

						<!-- Workout Programs -->
						<div class="flex gap-4">
							<div class="flex items-center justify-center w-12 h-12 rounded-xl bg-zinc-900 border border-zinc-800 text-yellow-400 shrink-0">
								<svg class="w-6 h-6 fill-none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
								</svg>
							</div>
							<div>
								<h3 class="text-white font-bold text-base uppercase">Specialized Fat Loss & Conditioning</h3>
								<p class="text-zinc-500 text-sm mt-1 leading-relaxed">
									Whether you want to build heavy lean muscle or get shredded, we provide customized exercises and high-intensity workout circuits tailored to you.
								</p>
							</div>
						</div>

					</div>
				</div>

			</div>
		</div>
	</section>

	<!-- Champions & Milestones (Hall of Fame) Section -->
	<section id="achievements" class="py-24 bg-[#050505] relative scroll-mt-20">
		<div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(250,204,21,0.02)_0,transparent_50%)]"></div>

		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
			<!-- Section Header -->
			<div class="text-center space-y-4 mb-16">
				<span class="text-sm font-bold text-yellow-400 uppercase tracking-widest block">Milestones & Titles</span>
				<h2 class="text-3xl sm:text-5xl font-black text-white uppercase tracking-tight">Hall of Fame</h2>
				<p class="text-zinc-500 text-sm sm:text-base max-w-lg mx-auto font-light">
					Empowering champions under Coach Malik Shahzad's direct guidelines. Explore our proud achievements.
				</p>
			</div>

			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
				<!-- Left Column: Coach's Achievements -->
				<div class="lg:col-span-6 space-y-8">
					<h3 class="text-xl sm:text-2xl font-black text-white uppercase tracking-tight border-l-4 border-yellow-400 pl-4">
						Coach Achievements
					</h3>
					
					<div class="space-y-4">
						<div class="flex items-center gap-4 p-5 rounded-2xl bg-zinc-900/40 border border-zinc-800/80 hover:border-yellow-400/20 transition-all">
							<div class="w-12 h-12 rounded-xl bg-yellow-400/10 text-yellow-400 flex items-center justify-center shrink-0">
								<svg class="w-6 h-6 animate-pulse" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><path d="M8.21 13.89 7 23l5-3 5 3-1.21-9.12"/></svg>
							</div>
							<div>
								<h4 class="text-white font-extrabold text-lg uppercase leading-tight">Mr. Sargodha Division</h4>
								<p class="text-zinc-500 text-sm mt-1">Overall Division Champion · 2009</p>
							</div>
						</div>

						<div class="flex items-center gap-4 p-5 rounded-2xl bg-zinc-900/40 border border-zinc-800/80 hover:border-yellow-400/20 transition-all">
							<div class="w-12 h-12 rounded-xl bg-yellow-400/10 text-yellow-400 flex items-center justify-center shrink-0">
								<svg class="w-6 h-6 animate-pulse" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><path d="M8.21 13.89 7 23l5-3 5 3-1.21-9.12"/></svg>
							</div>
							<div>
								<h4 class="text-white font-extrabold text-lg uppercase leading-tight">3x Mr. Punjab Runner-up</h4>
								<p class="text-zinc-500 text-sm mt-1">Punjab Bodybuilding Championship Runner-up · 2007, 2008, 2009</p>
							</div>
						</div>

						<div class="flex items-center gap-4 p-5 rounded-2xl bg-zinc-900/40 border border-zinc-800/80 hover:border-yellow-400/20 transition-all">
							<div class="w-12 h-12 rounded-xl bg-yellow-400/10 text-yellow-400 flex items-center justify-center shrink-0">
								<svg class="w-6 h-6 animate-pulse" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><path d="M8.21 13.89 7 23l5-3 5 3-1.21-9.12"/></svg>
							</div>
							<div>
								<h4 class="text-white font-extrabold text-lg uppercase leading-tight">Mr. Arm Wrestler Sargodha</h4>
								<p class="text-zinc-500 text-sm mt-1">Arm Wrestling Champion · 2010</p>
							</div>
						</div>
					</div>

					<!-- Certificates Subsection -->
					<div class="pt-6 space-y-4">
						<h4 class="text-sm font-bold text-zinc-400 uppercase tracking-widest">
							Professional Credentials
						</h4>
						<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
							<div class="p-5 rounded-2xl bg-zinc-900/20 border border-zinc-800 text-center space-y-3">
								<div class="w-10 h-10 rounded-full bg-yellow-400/10 text-yellow-400 flex items-center justify-center mx-auto">
									<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
								</div>
								<h5 class="text-white font-bold text-sm uppercase">Certified Fitness Trainer</h5>
								<p class="text-zinc-500 text-xs leading-normal">Credentialed specialist in fitness programs, execution, and exercise science.</p>
							</div>

							<div class="p-5 rounded-2xl bg-zinc-900/20 border border-zinc-800 text-center space-y-3">
								<div class="w-10 h-10 rounded-full bg-yellow-400/10 text-yellow-400 flex items-center justify-center mx-auto">
									<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
								</div>
								<h5 class="text-white font-bold text-sm uppercase">Certified Nutritionist</h5>
								<p class="text-zinc-500 text-xs leading-normal">Professional expertise in bodybuilding meal charts and custom diet plans.</p>
							</div>
						</div>
					</div>
				</div>

				<!-- Right Column: Student Champions -->
				<div class="lg:col-span-6 space-y-8">
					<h3 class="text-xl sm:text-2xl font-black text-white uppercase tracking-tight border-l-4 border-yellow-400 pl-4">
						Student Champions
					</h3>
					
					<div class="space-y-4">
						<div class="flex flex-col sm:flex-row items-center gap-5 p-5 rounded-3xl bg-zinc-900/40 border border-zinc-800/80 hover:border-yellow-400/20 transition-all">
							<div class="w-24 h-24 rounded-2xl overflow-hidden bg-zinc-950 shrink-0 border border-zinc-800">
								<img src="/malik-shehzad-coach.png" alt="Bilal - Student Champion" class="w-full h-full object-cover object-top filter grayscale contrast-110" />
							</div>
							<div class="text-center sm:text-left">
								<span class="text-xs font-bold text-yellow-400 uppercase tracking-wider">Title Holder</span>
								<h4 class="text-white font-extrabold text-lg uppercase leading-tight mt-0.5">Bilal</h4>
								<p class="text-zinc-500 text-sm mt-1">Mr. Sargodha Division Winner · 2022</p>
							</div>
						</div>

						<div class="flex flex-col sm:flex-row items-center gap-5 p-5 rounded-3xl bg-zinc-900/40 border border-zinc-800/80 hover:border-yellow-400/20 transition-all">
							<div class="w-24 h-24 rounded-2xl overflow-hidden bg-zinc-950 shrink-0 border border-zinc-800">
								<img src="/malik-shehzad-coach.png" alt="Arslan Sunny - Student Champion" class="w-full h-full object-cover object-top filter grayscale contrast-110" />
							</div>
							<div class="text-center sm:text-left">
								<span class="text-xs font-bold text-yellow-400 uppercase tracking-wider">Class Winner</span>
								<h4 class="text-white font-extrabold text-lg uppercase leading-tight mt-0.5">Arslan Sunny</h4>
								<p class="text-zinc-500 text-sm mt-1">Mr. Sargodha Senior Class Winner Title · 2022</p>
							</div>
						</div>

