	<script>
		const btnGents = document.getElementById('btn-gents');
		const btnLadies = document.getElementById('btn-ladies');
		const sectionGents = document.getElementById('section-gents');
		const sectionLadies = document.getElementById('section-ladies');
		const activeIndicator = document.getElementById('tab-active-indicator');

		if (btnGents && btnLadies && sectionGents && sectionLadies && activeIndicator) {
			btnGents.addEventListener('click', () => {
				// Show Gents Section
				sectionGents.classList.remove('hidden');
				sectionGents.classList.add('block');
				
				// Hide Ladies Section
				sectionLadies.classList.remove('block');
				sectionLadies.classList.add('hidden');
				
				// Button Styling
				btnGents.classList.add('text-black');
				btnGents.classList.remove('text-zinc-400', 'hover:text-white');
				
				btnLadies.classList.remove('text-black');
				btnLadies.classList.add('text-zinc-400', 'hover:text-white');
				
				// Translate Slider
				activeIndicator.style.transform = 'translateX(0px)';
			});

			btnLadies.addEventListener('click', () => {
				// Show Ladies Section
				sectionLadies.classList.remove('hidden');
				sectionLadies.classList.add('block');
				
				// Hide Gents Section
				sectionGents.classList.remove('block');
				sectionGents.classList.add('hidden');
				
				// Button Styling
				btnLadies.classList.add('text-black');
				btnLadies.classList.remove('text-zinc-400', 'hover:text-white');
				
				btnGents.classList.remove('text-black');
				btnGents.classList.add('text-zinc-400', 'hover:text-white');
				
				// Translate Slider (145px width of one tab)
				activeIndicator.style.transform = 'translateX(145px)';
			});
		}

		// Reviews Slider Navigation & Autoplay
		const track = document.getElementById('reviews-track');
		const prevBtn = document.getElementById('btn-prev-review');
		const nextBtn = document.getElementById('btn-next-review');

		if (track) {
			let scrollInterval: any;
			
			const startAutoplay = () => {
				scrollInterval = setInterval(() => {
					// Card width (350px) + Gap (24px) = 374px
					const maxScroll = track.scrollWidth - track.clientWidth;
					if (track.scrollLeft >= maxScroll - 10) {
						track.scrollTo({ left: 0, behavior: 'smooth' });
					} else {
						track.scrollBy({ left: 374, behavior: 'smooth' });
					}
				}, 4000);
			};

			const stopAutoplay = () => {
				if (scrollInterval) clearInterval(scrollInterval);
			};

			startAutoplay();

			// Pause autoplay on interaction
			track.addEventListener('mouseenter', stopAutoplay);
			track.addEventListener('mouseleave', startAutoplay);
			track.addEventListener('touchstart', stopAutoplay, { passive: true });
			track.addEventListener('touchend', startAutoplay, { passive: true });

			if (prevBtn && nextBtn) {
				prevBtn.addEventListener('click', () => {
					stopAutoplay();
					track.scrollBy({ left: -374, behavior: 'smooth' });
					startAutoplay();
				});
				nextBtn.addEventListener('click', () => {
					stopAutoplay();
					track.scrollBy({ left: 374, behavior: 'smooth' });
					startAutoplay();
				});
			}
		}

		// FAQ Accordions Toggle
		const faqButtons = document.querySelectorAll('.faq-btn');
		faqButtons.forEach((btn) => {
			btn.addEventListener('click', () => {
				const content = btn.nextElementSibling;
				const chevron = btn.querySelector('.faq-chevron');

				// Close other open items
				faqButtons.forEach((otherBtn) => {
					if (otherBtn !== btn) {
						const otherContent = otherBtn.nextElementSibling;
						const otherChevron = otherBtn.querySelector('.faq-chevron');
						if (otherContent) {
							(otherContent as any).style.maxHeight = null;
						}
						if (otherChevron) otherChevron.classList.remove('rotate-180');
					}
				});

				// Toggle current item
				if (content) {
					if ((content as any).style.maxHeight) {
						(content as any).style.maxHeight = null;
						if (chevron) chevron.classList.remove('rotate-180');
					} else {
						(content as any).style.maxHeight = (content as any).scrollHeight + "px";
						if (chevron) chevron.classList.add('rotate-180');
					}
				}
			});
		});
	</script>
